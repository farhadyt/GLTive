# Purpose: Template for environment variables required by GLTive backend

# =========================
# Django
# =========================
DJANGO_SETTINGS_MODULE=config.settings.development
# REQUIRED in production — minimum 50 characters, cryptographically random
# Development: use any value >= 32 chars to avoid JWT warnings
DJANGO_SECRET_KEY=change-me-to-a-real-secret-key-at-least-fifty-chars-long!
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# =========================
# Database (PostgreSQL)
# =========================
DATABASE_NAME=gltive
DATABASE_USER=gltive
DATABASE_PASSWORD=gltive_dev_password
DATABASE_HOST=localhost
DATABASE_PORT=5432

# =========================
# Redis
# =========================
REDIS_URL=redis://localhost:6379/0

# =========================
# Celery
# =========================
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# =========================
# JWT Auth
# =========================
JWT_ACCESS_TOKEN_LIFETIME_MINUTES=60
JWT_REFRESH_TOKEN_LIFETIME_DAYS=7

# =========================
# Localization
# =========================
LANGUAGE_CODE=en
TIME_ZONE=UTC

# =========================
# Production-only settings
# =========================
# CORS_ALLOWED_ORIGINS=https://app.example.com,https://admin.example.com
# SECURE_SSL_REDIRECT=True
