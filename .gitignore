# Purpose: Git ignore rules for GLTive platform

# =========================
# Python / Django
# =========================
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.pyc
*.sqlite3
*.db
*.log

# Virtual environments
venv/
.venv/
env/
ENV/

# Django generated
media/
staticfiles/
local_settings.py

# =========================
# Environment / secrets
# =========================
.env
.env.*
!.env.example
*.pem
*.key
*.crt
secrets/

# =========================
# Node / React
# =========================
node_modules/
dist/
build/
coverage/
.next/
out/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# =========================
# Testing / cache
# =========================
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/
.cache/

# =========================
# Celery / temp
# =========================
celerybeat-schedule
*.pid
tmp/
temp/
migrate.txt

# =========================
# Docker / local overrides
# =========================
docker-compose.override.yml

# =========================
# IDE / OS
# =========================
.vscode/
.idea/
.DS_Store
Thumbs.db
desktop.ini